{
  "author": {
    "email": "km.8k6ce+npm@gmail.com",
    "name": "kei-g"
  },
  "bugs": {
    "url": "https://github.com/kei-g/async-iterable-queue/issues"
  },
  "description": "Async Iterable Queue",
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^26.1.1",
    "c8": "^11.0.0",
    "esbuild": "^0.28.1",
    "esbuild-register": "^3.6.0",
    "npm-run-all2": "^9.0.2",
    "rimraf": "^6.1.3",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=14.17.5"
  },
  "homepage": "https://github.com/kei-g/async-iterable-queue",
  "keywords": [
    "async",
    "asynchronous",
    "asynciterable",
    "asynciterator",
    "iterable",
    "queue"
  ],
  "license": "BSD-3-Clause",
  "main": "index.js",
  "name": "async-iterable-queue",
  "overrides": {
    "c8": {
      "yargs": "^18.0.0"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": "github:kei-g/async-iterable-queue",
  "scripts": {
    "build": "npm-run-all2 --parallel build:bundle build:tsc",
    "build:bundle": "esbuild src/index.ts --bundle --minify --outfile=index.js --platform=node --target=ES2015",
    "build:tsc": "tsc",
    "clean": "rimraf coverage/ index.d.ts index.js lib/",
    "cover": "c8 node --test",
    "lint": "biome lint --write",
    "postbuild:tsc": "tar -C types/src -cf - . | tar -xf - && rm -fr types",
    "postpublish": "npm run clean",
    "prebuild": "npm-run-all2 --parallel clean lint",
    "prepublishOnly": "npm run build",
    "start": "node --require esbuild-register example.ts",
    "test": "npm-run-all2 --parallel lint cover"
  },
  "type": "module",
  "types": "index.d.ts",
  "version": "1.0.16"
}
